# ============================================================
# Website Recovery Crawler — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# Target website to crawl (required)
CRAWL_URL=https://example.com

# Maximum crawl depth from the root URL (default: 10)
CRAWL_DEPTH=10

# Number of pages to process concurrently (default: 3)
CRAWL_CONCURRENCY=3

# Milliseconds to wait between page requests — rate limiting (default: 500)
CRAWL_DELAY_MS=500

# Milliseconds to wait for network idle after navigation (default: 5000)
CRAWL_NETWORK_IDLE_MS=5000

# Maximum retries for failed requests (default: 3)
CRAWL_MAX_RETRIES=3

# Comma-separated list of additional allowed external domains
# CRAWL_ALLOWED_DOMAINS=cdn.example.com,fonts.googleapis.com

# Directory to write crawl output (default: ./output)
OUTPUT_DIR=./output

# Whether to scroll pages to trigger lazy loading (default: true)
CRAWL_SCROLL=true

# Whether to take debug screenshots on page errors (default: true)
CRAWL_DEBUG_SCREENSHOTS=true

# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# Set to true for human-readable log output (default: true)
LOG_PRETTY=true

# Viewport width in pixels (default: 1280)
VIEWPORT_WIDTH=1280

# Viewport height in pixels (default: 900)
VIEWPORT_HEIGHT=900

# User-agent string override (leave blank to use Playwright default)
# USER_AGENT=

# Timeout in milliseconds for individual page loads (default: 30000)
PAGE_TIMEOUT_MS=30000

# Maximum total pages to crawl (0 = unlimited, default: 0)
MAX_PAGES=0
